# Environment Variables Template
# Copy this file to .env and fill in your actual values

# === DISCORD BOT CONFIGURATION ===
# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Main Discord channel ID for death announcements (right-click channel > Copy ID)
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Discord server (guild) ID (right-click server name > Copy ID)
DISCORD_GUILD_ID=your_discord_server_id_here

# Friendly name for your Minecraft server (appears in announcements)
SERVER_NAME=Friends MC Server

# === SESSION NOTIFICATIONS (Player Online/Offline) ===
# Enable/disable the new player session notification feature
SESSION_NOTIFICATIONS_ENABLED=true

# Discord role ID to mention when players join (e.g., @Crafters)
CRAFTERS_ROLE_ID=your_crafters_role_id_here

# Discord channel ID for "who is on" notifications (separate from death channel)
WHO_IS_ON_CHANNEL_ID=your_who_is_on_channel_id_here

# Cooldown in seconds before posting new JOIN notifications (prevents spam)
SESSION_COOLDOWN_SECONDS=120

# === FTP SERVER ACCESS (Minecraft Server Logs) ===
# FTP host of your Minecraft server
FTP_HOST=your_minecraft_server_ftp_host

# FTP port (usually 21)
FTP_PORT=21

# FTP username for accessing server logs
FTP_USER=your_ftp_username

# FTP password for accessing server logs
FTP_PASSWORD=your_ftp_password

# Path to the latest.log file on your FTP server
FTP_LOG_PATH=/logs/latest.log

# How often to check for new log entries (seconds)
LOG_CHECK_INTERVAL=10

# === DATABASE CONFIGURATION ===
# PostgreSQL connection string (recommended for production)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:pass@host:port/db

# === TIMEZONE & SCHEDULING ===
# Timezone for daily leaderboard announcements
TIMEZONE=America/New_York
