# Environment Variables
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here  
DISCORD_GUILD_ID=your_discord_server_id_here

# Join/Leave announcements
CRAFTERS_ROLE_ID=your_crafters_role_id_here
WHO_IS_ON_CHANNEL_ID=your_who_is_on_channel_id_here

# FTP Log Access
FTP_HOST=your_minecraft_server_ip
FTP_PORT=21
FTP_USER=your_ftp_username
FTP_PASSWORD=your_ftp_password
FTP_LOG_PATH=/path/to/latest.log

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/discordmcbot

# Server Configuration
SERVER_NAME=Friends MC Server
LOG_CHECK_INTERVAL=10
TIMEZONE=America/New_York
